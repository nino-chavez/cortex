{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cortex",
  "version": "0.1.0",
  "identifier": "app.cortex.dev",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:4173",
    "beforeDevCommand": "npm run dev -- --port 4173 --strictPort",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Cortex",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
