{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cortex",
  "version": "0.1.0",
  "identifier": "app.cortex.dev",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:4173",
    "beforeDevCommand": "npm run dev -- --port 4173 --strictPort",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Cortex",
        "label": "main",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "search",
        "url": "/search",
        "title": "",
        "width": 720,
        "height": 520,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "resizable": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.cortex/**"]
      }
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
